{
  "name": "@effectionx/middleware",
  "description": "Type-safe composable middleware for generators and Effection operations",
  "version": "0.1.0",
  "keywords": ["concurrency", "interop"],
  "type": "module",
  "main": "./dist/mod.js",
  "types": "./dist/mod.d.ts",
  "exports": {
    ".": {
      "types": "./dist/mod.d.ts",
      "development": "./mod.ts",
      "import": "./dist/mod.js",
      "default": "./dist/mod.js"
    }
  },
  "files": ["dist", "mod.ts", "middleware.ts"],
  "license": "MIT",
  "author": "engineering@frontside.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thefrontside/effectionx.git"
  },
  "bugs": {
    "url": "https://github.com/thefrontside/effectionx/issues"
  },
  "engines": {
    "node": ">= 22"
  },
  "sideEffects": false
}
